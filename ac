#!/usr/bin/env python3
import argparse
import os
import subprocess
import sys
from pathlib import Path

# --- Constants & Configuration ---
BASE_DIR = Path("/home/natsuko/AtCoder_env")
VENV_PYTHON = BASE_DIR / ".venv" / "bin" / "python"

# ANSI Colors
C_GRAY = "\033[90m"
C_BLUE = "\033[94m"
C_GREEN = "\033[92m"
C_RED = "\033[91m"
C_YELLOW = "\033[93m"
C_CYAN = "\033[96m"
C_PURPLE = "\033[95m"
C_BOLD = "\033[1m"
C_RESET = "\033[0m"
C_BG_RED = "\033[101m\033[97m"
C_BG_GREEN = "\033[102m\033[30m"
C_BG_YELLOW = "\033[103m\033[30m"
C_BG_BLUE = "\033[104m\033[97m"

# --- Utility Functions ---

def run_cmd(cmd, cwd=None):
    """Run a command and exit on failure."""
    process = subprocess.run(cmd, shell=True, cwd=cwd)
    if process.returncode != 0:
        sys.exit(process.returncode)

def format_test_line(line):
    """Format a single line of output from 'oj t' to look premium."""
    line = line.strip()
    if not line:
        return None

    # Ignore unnecessary logs
    ignore_keywords = [
        "[NETWORK]", "load cookie", "save cookie", "online-judge-tools", 
        "You are logged in.", "online-judge-api-client", "both GCC and Clang", 
        "use: GCC", "chosen language:", "cases found"
    ]
    if any(kw in line for kw in ignore_keywords):
        return None

    # Result mapping
    if line.startswith("[INFO] sample-"):
        case_name = line.replace('[INFO] ', '')
        return f"\n{C_BOLD}{C_CYAN}🔎 テストケース: {case_name}{C_RESET}\n{C_GRAY}{'─' * 60}{C_RESET}"
    
    if line.startswith("[INFO] time:"):
        return f"  {C_GRAY}⏱️  Time: {C_RESET}{line.replace('[INFO] time: ', '')}"
    
    if "[SUCCESS] AC" in line:
        return f"  {C_BG_GREEN}{C_BOLD} PASS {C_RESET} {C_GREEN}Accepted (正解){C_RESET}"
    
    if "[FAILURE] WA" in line:
        return f"  {C_BG_RED}{C_BOLD} FAIL {C_RESET} {C_RED}Wrong Answer (誤答){C_RESET}"
    
    if "[FAILURE] RE" in line:
        return f"  {C_BG_YELLOW}{C_BOLD} ERRR {C_RESET} {C_YELLOW}Runtime Error (実行時エラー){C_RESET}"
    
    if "[FAILURE] TLE" in line:
        return f"  {C_BG_YELLOW}{C_BOLD} TIME {C_RESET} {C_YELLOW}Time Limit Exceeded (時間切れ){C_RESET}"
    
    # Header mapping
    if line == "input:":
        return f"  {C_BOLD}{C_BLUE}📥 INPUT{C_RESET}"
    if line == "output:":
        return f"  {C_BOLD}{C_PURPLE}📤 YOUR OUTPUT{C_RESET}"
    if line == "expected:":
        return f"  {C_BOLD}{C_GREEN}✅ EXPECTED{C_RESET}"
    if line == "(empty)":
        return f"    {C_GRAY}(空データ){C_RESET}"

    # Summary mapping
    if line.startswith("[INFO] max memory:"):
        return f"\n  {C_GRAY}📊 Max Memory: {C_RESET}{line.replace('[INFO] max memory: ', '')}"
    
    if line.startswith("[INFO] slowest:"):
        return f"  {C_GRAY}🐢 Slowest:    {C_RESET}{line.replace('[INFO] slowest: ', '')}"
    
    if "[FAILURE] test failed:" in line:
        res = line.replace("[FAILURE] test failed: ", "")
        return f"\n{C_BG_RED}{C_BOLD}  RESULT: FAILED  {C_RESET} {C_RED}テスト通過: {res}{C_RESET}"
    
    if "[SUCCESS] test success:" in line:
        res = line.replace("[SUCCESS] test success: ", "")
        return (
            f"\n{C_BG_GREEN}{C_BOLD}  RESULT: SUCCESS  {C_RESET} {C_GREEN}全問正解! ({res}){C_RESET}\n"
            f"  {C_BOLD}🎉 おめでとうございます！このまま提出可能です。{C_RESET}"
        )

    # Default: Indented raw output for data
    return f"    {line}"

def run_test_cmd(cmd, cwd=None):
    """Run test command and format output."""
    print(f"{C_GRAY}⚙️ テストを実行しています...{C_RESET}")
    process = subprocess.Popen(
        cmd, shell=True, cwd=cwd,
        stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
        universal_newlines=True
    )
    
    if process.stdout:
        for line in process.stdout:
            formatted = format_test_line(line)
            if formatted:
                print(formatted)
    
    process.wait()

def get_contest_info_from_cwd():
    """Detect contest type, number, and problem from CWD."""
    try:
        cwd = Path.cwd()
        rel_path = cwd.relative_to(BASE_DIR)
        parts = rel_path.parts
        if len(parts) >= 3:
            return parts[0], parts[1], parts[2]
        if len(parts) >= 2:
            return parts[0], parts[1], None
    except ValueError:
        pass
    return None, None, None

def get_target_dir(ctype, number, problem=None):
    """Get absolute path to problem directory."""
    path = BASE_DIR / ctype / str(number)
    if problem:
        path = path / problem
    return path

def get_active_language(target_dir):
    """Determine the active language based on file modification time."""
    cpp_file = target_dir / "main.cpp"
    py_file = target_dir / "main.py"
    
    cpp_time = cpp_file.stat().st_mtime if cpp_file.exists() else 0
    py_time = py_file.stat().st_mtime if py_file.exists() else 0
    
    if py_time > cpp_time:
        return "main.py", f"{VENV_PYTHON} main.py"
    else:
        return "main.cpp", "g++ -std=c++17 -O2 main.cpp && ./a.out"

# --- Command Handlers ---

def fetch(args):
    """Handler for 'fetch' command."""
    cmd = f"{BASE_DIR}/scripts/generate_contest.sh {args.type} {args.number}"
    run_cmd(cmd)

def test(args):
    """Handler for 'test' command."""
    ctype, number, problem = args.type, args.number, args.problem
    
    # Auto-detection
    d_ctype, d_number, d_problem = get_contest_info_from_cwd()
    ctype = ctype or d_ctype
    number = number or d_number
    problem = problem or d_problem

    if not all([ctype, number, problem]):
        print(f"{C_RED}Error{C_RESET}: Contest type, number, and problem are required (or run from a problem directory).")
        return

    target_dir = get_target_dir(ctype, number, problem)
    if not target_dir.exists():
        print(f"{C_RED}Error{C_RESET}: Directory {target_dir} does not exist.")
        return
    
    filename, exec_cmd = get_active_language(target_dir)
    print(f"{C_CYAN}[INFO]{C_RESET} 編集中のファイル {C_BOLD}{filename}{C_RESET} をテストします...")
    
    cmd = f"uv run oj t -c '{exec_cmd}' -d tests"
    run_test_cmd(cmd, cwd=target_dir)

def submit(args):
    """Handler for 'submit' command."""
    ctype, number, problem = args.type, args.number, args.problem
    
    # Auto-detection
    d_ctype, d_number, d_problem = get_contest_info_from_cwd()
    ctype = ctype or d_ctype
    number = number or d_number
    problem = problem or d_problem

    if not all([ctype, number, problem]):
        print(f"{C_RED}Error{C_RESET}: Contest type, number, and problem are required (or run from a problem directory).")
        return

    target_dir = get_target_dir(ctype, number, problem)
    if not target_dir.exists():
        print(f"{C_RED}Error{C_RESET}: Directory {target_dir} does not exist.")
        return

    filename, _ = get_active_language(target_dir)
    print(f"{C_CYAN}[INFO]{C_RESET} {C_BOLD}{filename}{C_RESET} を提出します...")
    
    if filename.endswith(".py"):
        # Pythonファイルの場合は自動的にPyPyを優先して提出する
        cmd = f"acc s {filename} -- --guess-python-interpreter pypy"
    else:
        cmd = f"acc s {filename}"
        
    run_cmd(cmd, cwd=target_dir)

# --- Main Entry Point ---

def main():
    parser = argparse.ArgumentParser(description="AtCoder Wrapper (ac)")
    subparsers = parser.add_subparsers(dest="command", required=True)

    # fetch
    p_fetch = subparsers.add_parser("fetch", help="環境構築 (例: ac fetch abc 300)")
    p_fetch.add_argument("type", help="コンテスト種別 (abc, arc など)")
    p_fetch.add_argument("number", help="回数 (300 など)")

    # test
    p_test = subparsers.add_parser("test", help="テスト実行 (例: ac test abc 300 a)")
    p_test.add_argument("type", nargs='?', default=None)
    p_test.add_argument("number", nargs='?', default=None)
    p_test.add_argument("problem", nargs='?', help="問題 (a, b, c など)", default=None)

    # submit
    p_submit = subparsers.add_parser("submit", help="提出 (例: ac submit abc 300 a)")
    p_submit.add_argument("type", nargs='?', default=None)
    p_submit.add_argument("number", nargs='?', default=None)
    p_submit.add_argument("problem", nargs='?', default=None)

    args = parser.parse_args()

    handlers = {
        "fetch": fetch,
        "test": test,
        "submit": submit
    }

    try:
        handlers[args.command](args)
    except KeyboardInterrupt:
        print(f"\n{C_RED}[Canceled]{C_RESET}")
    except Exception as e:
        print(f"\n{C_RED}[Error]{C_RESET} {e}")

if __name__ == '__main__':
    main()
